{
  "AWS": {"S3": {
    "BUCKET_NAME": "stock-market-network-analysis",
    "AWS_DEFAULT_REGION": "eu-north-1",
    "OUTPUT_FORMAT": "json",
    "FILENAMES_TO_LOAD": [
      "data/wrds_funda_gross_query.parquet",
      "data/wrds_gross_query_small.parquet",
      "data/russell_returns.parquet",
      "data/risk_free_returns.parquet"
    ],
    "DATES_FILENAME": "data/wrds_gross_query_small.parquet",
    "MKT_RETURNS_FILENAME": "data/russell_returns.parquet",
    "RF_RETURNS_FILENAME": "data/risk_free_returns.parquet"
  }},
  "DATA": {
    "DATA_FREQ": "d",
    "TARGET_VARIABLE": "dummy_forward_max_drawdown",
    "TARGET_VARIABLE_ROLLING_WINDOW": 21,
    "QUANTILE_FOR_DUMMY": 0.10,
    "RETURNS_TYPE": "idio",
    "MKT_BENCHMARK_COLUMN": "Russell 1000",
    "LIMIT_FFILL_BETAS": 5,
    "LIMIT_FFILL_RF": 10
  },
  "FORECASTING": {
    "FORECASTING_HORIZON": 0,
    "LOOKBACK_CORR": 252,
    "INNER_TRAIN_SIZE": 252,
    "INNER_VAL_SIZE": 42,
    "INNER_STEP_SIZE": 1,
    "THRESHOLD_GRID": [0.75],
    "MODEL_GRID": [
      {
        "model": "LogisticRegression",
        "model_kwargs": {"solver": "liblinear", "class_weight": "balanced", "max_iter": 1000},
        "param_grid": [{"C": 1.0}]
      }
    ]
  }
}