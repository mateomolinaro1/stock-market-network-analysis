{
  "AWS": {"S3": {
    "BUCKET_NAME": "stock-market-network-analysis",
    "AWS_DEFAULT_REGION": "eu-north-1",
    "OUTPUT_FORMAT": "json",
    "FILENAMES_TO_LOAD": [
      "data/wrds_funda_gross_query.parquet",
      "data/wrds_gross_query_small.parquet",
      "data/russell_returns.parquet",
      "data/risk_free_returns.parquet"
    ],
    "DATES_FILENAME": "data/wrds_gross_query_small.parquet",
    "MKT_RETURNS_FILENAME": "data/russell_returns.parquet",
    "RF_RETURNS_FILENAME": "data/risk_free_returns.parquet"
  }},
  "DATA": {
    "DATA_FREQ": "d",
    "TARGET_VARIABLE": "dummy_forward_max_drawdown",
    "TARGET_VARIABLE_ROLLING_WINDOW": 21,
    "QUANTILE_FOR_DUMMY": 0.20,
    "RETURNS_TYPE": "raw",
    "MKT_BENCHMARK_COLUMN": "Russell 1000",
    "LIMIT_FFILL_BETAS": 5,
    "LIMIT_FFILL_RF": 10
  },
  "FORECASTING": {
    "FORECASTING_HORIZON": 0,
    "LOOKBACK_CORR": 252,
    "INNER_TRAIN_SIZE": 252,
    "INNER_VAL_SIZE": 42,
    "INNER_STEP_SIZE": 1,
    "SCORING_METRIC": "pr_auc",
    "LOAD_OR_COMPUTE_CV": "compute",
    "SAVE_CV": true,
    "HALFLIFE_CORR": 63,
    "EXPANDING_OR_ROLLING": "expanding",
    "FEATURE_MODES": ["ts", "network"],
    "THRESHOLD_GRID": [0.75],
    "MODEL_GRID": [
      {
        "model": "LogisticRegression",
        "scale": true,
        "model_kwargs": {"solver": "saga", "l1_ratio": 1, "class_weight": "balanced", "max_iter": 2000},
        "param_grid": [{"C": 0.1}]
      }
    ]
  },
  "NETWORK_ANALYTICS": {
    "MAX_FRAMES": 180,
    "NORMALIZE_DEGREE_COUNTS": true,
    "DEGREE_XSCALE": "log",
    "DEGREE_YSCALE": "log",
    "DEGREE_Y_MAX_QUANTILE": null,
    "DEGREE_PLOT_KIND": "pmf",
    "DEGREE_LOG_BINS": null,
    "DEGREE_THRESHOLD": null,
    "NORMALIZE_RICH_CLUB": true,
    "N_RANDOM_REFERENCE": 3,
    "RANDOM_SWAPS_PER_EDGE": 5,
    "RICH_CLUB_XSCALE": "log",
    "RICH_CLUB_YSCALE": "linear",
    "REGIME_MAX_DATES": null,
    "SHOW_POWER_LAW": true,
    "POWER_LAW_MIN_DEGREE": null,
    "POWER_LAW_MAX_DEGREE": null,
    "DEGREE_MIXING_N_BINS": 15,
    "DEGREE_MIXING_MAX_POINTS_PER_REGIME": 15000
  }
}
